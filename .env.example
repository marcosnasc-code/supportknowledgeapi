# Copie para .env na raiz do projeto:  copy .env.example .env
# O arquivo .env não é versionado (.gitignore).

# PostgreSQL (Docker)
POSTGRES_DB=support_knowledge
POSTGRES_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres

# Spring Boot lê DB_USER e DB_PASSWORD para jdbc:postgresql://localhost:5432/support_knowledge
